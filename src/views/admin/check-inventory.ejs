<% layout('layout/boilerplate.ejs') %>
<link rel="stylesheet" href="/style/check-inventory.css">



<div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
  <div class="">
    <h2 class="fw-bold mb-0">Inventaris <span class="text-muted fs-5 fw-normal">/ (<%= totalBarang %>)</span></h2>
  </div>
  <div>
    <a href="/admin/input-inventory" class="btn btn-add px-4 py-2" style="border-radius: 8px;">
      <i class="bi bi-plus-lg"></i> Tambah Barang
    </a>
  </div>
</div>

<div class="inventory-wrapper">
  <% if(inventories.length === 0){ %>
  <div class="alert alert-warning text-center mb-0">Belum ada data barang.</div>
  <% } else { %>
  <div class="table-responsive">
    <table class="table table-borderless align-middle mb-0">
      <thead class="table-header border-bottom">
        <tr>
          <th scope="col">Name Barang</th>
          <th scope="col">Kategori</th>
          <th scope="col">Ruangan</th>
          <th scope="col">Jumlah & Satuan</th>
          <th scope="col" class="text-end">Action</th>
        </tr>
      </thead>
      <tbody>
        <% for(let barang of inventories){ %>
        <tr class="border-bottom">


          <td>
            <div class="d-flex align-items-center">
              <img src="<%= barang.image_url || '/placeholder.jpg' %>" alt="<%= barang.nama_barang %>" class="product-image">
              <span class="fw-normal text-dark"><%= barang.nama_barang %></span>
            </div>
          </td>

          <td>
            <div class="d-flex align-items-center">
              <span class="fw-normal text-dark"><%= barang.kategori %></span>
            </div>
          </td>

          <td>
            <div class="d-flex align-items-center">
              <span class="fw-normal text-dark"><%= barang.ruangan %></span>
            </div>
          </td>

          <td>
            <div class="d-flex align-items-center">
              <span class="fw-normal text-dark"><%= barang.jumlah %> <%= barang.satuan %></span>
            </div>
          </td>


          <td class="text-end">
            <div class="d-flex justify-content-end align-items-center">

              <a href="/admin/item-detail/<%= barang.id_barang %>" class="action-btn text-decoration-none" title="Lihat Detail">
                <i class="bi bi-eye"></i>
              </a>

              <a href="/admin/item-detail/<%= barang.id_barang %>/edit" class="action-btn text-decoration-none" title="Edit">
                <i class="bi bi-pencil"></i>
              </a>

              <a href="/admin/item-detail/<%= barang.id_barang %>/qr-code" class="action-btn text-decoration-none" title="QR Code">
                <i class="bi bi-qr-code-scan"></i>
              </a>

              <form action="/admin/item-detail/<%= barang.id_barang %>?_method=DELETE" method="POST" class="m-0">
                <button type="submit" class="btn btn-link action-btn p-0 m-0 border-0 text-decoration-none d-flex align-items-center" title="Hapus" onclick="return confirm('Yakin ingin menghapus barang ini?')">
                  <i class="bi bi-trash"></i>
                </button>
              </form>

            </div>
          </td>
          <% } %>
      </tbody>
    </table>
  </div>

  <% if (totalPages > 1) { %>
  <div class="d-flex justify-content-end mt-4 pt-3">
    <nav aria-label="Inventory pagination">
      <ul class="pagination pagination-custom">

        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
          <a class="page-link" href="<%= currentPage === 1 ? '#' : '/admin/check-inventory/?page=' + (currentPage - 1) + '&limit=' + limit %>">
            <i class="bi bi-chevron-left" style="font-size: 0.8rem;"></i>
          </a>
        </li>

        <% 
        let startPage = 1;
        let endPage = totalPages;
        
        // Membatasi tampilan maksimal 5 halaman + elipsis
        if (totalPages > 5) {
            if (currentPage <= 3) {
                endPage = 5;
            } else if (currentPage >= totalPages - 2) {
                startPage = totalPages - 4;
            } else {
                startPage = currentPage - 2;
                endPage = currentPage + 2;
            }
        }
        %>

        <% for (let i = startPage; i <= endPage; i++) { %>
        <li class="page-item <%= i === currentPage ? 'active' : '' %>">
          <a class="page-link" href="/admin/check-inventory/?page=<%= i %>&limit=<%= limit %>">
            <%= i %>
          </a>
        </li>
        <% } %>

        <% if (endPage < totalPages) { %>
        <li class="page-item disabled">
          <span class="page-link border-0 text-secondary bg-transparent">...</span>
        </li>
        <% } %>

        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
          <a class="page-link" href="<%= currentPage === totalPages ? '#' : '/admin/check-inventory/?page=' + (currentPage + 1) + '&limit=' + limit %>">
            <i class="bi bi-chevron-right" style="font-size: 0.8rem;"></i>
          </a>
        </li>

      </ul>
    </nav>
  </div>
  <% } %>
  <% } %>
</div>