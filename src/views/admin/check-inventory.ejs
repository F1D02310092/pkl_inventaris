<% layout('layout/boilerplate.ejs') %>

<style>
  .inventory-wrapper {
    background-color: #ffffff;
    border-radius: 12px;
    border: 1px solid #f0f0f0;
    padding: 20px;
  }

  .table-header {
    background-color: #f8f9fa;
    color: #495057;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .product-image {
    width: 40px;
    height: 40px;
    object-fit: contain;
    border-radius: 8px;
    border: 1px solid #e9ecef;
    margin-right: 15px;
  }

  .btn-add {
    background-color: #34c759;
    border-color: #34c759;
    color: white;
    font-weight: 500;
  }

  .btn-add:hover {
    background-color: #2db84d;
    color: white;
  }

  .action-btn {
    color: #6c757d;
    font-size: 1.1rem;
    margin-right: 10px;
    transition: color 0.2s;
  }

  .action-btn:hover {
    color: #212529;
  }

  .custom-input {
    border-radius: 8px;
    border: 1px solid #e0e0e0;
  }
</style>



<div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
  <div class="">
    <h2 class="fw-bold mb-0">Inventaris <span class="text-muted fs-5 fw-normal">/ (<%= inventories.length %>)</span></h2>
  </div>
  <div>
    <a href="/admin/input-inventory" class="btn btn-add px-4 py-2" style="border-radius: 8px;">
      <i class="bi bi-plus-lg"></i> Tambah Barang
    </a>
  </div>
</div>

<div class="inventory-wrapper">
  <% if(inventories.length === 0){ %>
  <div class="alert alert-warning text-center mb-0">Belum ada data barang.</div>
  <% } else { %>
  <div class="table-responsive">
    <table class="table table-borderless align-middle mb-0">
      <thead class="table-header border-bottom">
        <tr>

          <th scope="col">Name Barang</th>
          <th scope="col">Kategori</th>
          <th scope="col">Ruangan</th>
          <th scope="col">Jumlah & Satuan</th>
          <th scope="col">Merek</th>
          <th scope="col" class="text-end">Action</th>
        </tr>
      </thead>
      <tbody>
        <% for(let barang of inventories){ %>
        <tr class="border-bottom">


          <td>
            <div class="d-flex align-items-center">
              <img src="<%= barang.image_url || '/placeholder.jpg' %>" alt="<%= barang.nama_barang %>" class="product-image">
              <span class="fw-normal text-dark"><%= barang.nama_barang %></span>
            </div>
          </td>

          <td>
            <div class="d-flex align-items-center">
              <span class="fw-normal text-dark"><%= barang.kategori %></span>
            </div>
          </td>

          <td>
            <div class="d-flex align-items-center">
              <span class="fw-normal text-dark"><%= barang.ruangan %></span>
            </div>
          </td>

          <td>
            <div class="d-flex align-items-center">
              <span class="fw-normal text-dark"><%= barang.jumlah %> <%= barang.satuan %></span>
            </div>
          </td>
          <td>
            <div class="d-flex align-items-center">
              <%if(barang.merek !== ""){%>
              <span class="fw-normal text-dark"><%= barang.merek %></span>
              <%} else {%>
              <span class="fw-normal text-dark">-</span>
              <%}%>
            </div>
          </td>

          <td class="text-end">
  <div class="d-flex justify-content-end align-items-center">
    
    <a href="/admin/item-detail/<%= barang.id_barang %>" class="action-btn text-decoration-none" title="View Detail">
              <i class="bi bi-eye"></i>
              </a>

              <a href="/admin/item-detail/<%= barang.id_barang %>/edit" class="action-btn text-decoration-none" title="Edit">
                <i class="bi bi-pencil"></i>
              </a>

              <a href="/admin/item-detail/<%= barang.id_barang %>/qr-code" class="action-btn text-decoration-none" title="QR Code">
                <i class="bi bi-qr-code-scan"></i>
              </a>

              <form action="/admin/item-detail/<%= barang.id_barang %>?_method=DELETE" method="POST" class="m-0">
                <button type="submit" class="btn btn-link action-btn p-0 m-0 border-0 text-decoration-none d-flex align-items-center" title="Delete" onclick="return confirm('Yakin ingin menghapus barang ini?')">
                  <i class="bi bi-trash"></i>
                </button>
              </form>

            </div>
          </td>
          <% } %>
      </tbody>
    </table>
  </div>


  <% } %>
</div>