<% layout('layout/boilerplate.ejs') %>

<style>
  .inventory-wrapper {
    background-color: #ffffff;
    border-radius: 12px;
    border: 1px solid #f0f0f0;
    padding: 30px;
  }

  .section-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #212529;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #f0f0f0;
  }

  .item-image {
    width: 100%;
    border-radius: 12px;
    border: 1px solid #e9ecef;
    object-fit: cover;
  }

  .img-placeholder {
    height: 350px;
    border-radius: 12px;
    background-color: #f8f9fa;
    border: 1px dashed #dee2e6;
  }

  .status-badge {
    font-size: 0.75rem;
    padding: 4px 12px;
    border-radius: 50px;
    font-weight: 600;
  }

  .status-pending {
    background-color: #fff3cd;
    color: #856404;
    border: 1px solid #ffeeba;
  }

  .basic-table th {
    color: #6c757d;
    font-weight: 500;
    font-size: 0.95rem;
    padding-left: 0;
    width: 200px;
  }

  .basic-table td {
    font-weight: 600;
    color: #212529;
  }

  .btn-green {
    background-color: #34c759;
    border-color: #34c759;
    color: white;
    font-weight: 500;
    border-radius: 8px;
  }

  .btn-green:hover {
    background-color: #2db84d;
    color: white;
  }

  .btn-light-custom {
    background-color: #ffffff;
    border: 1px solid #dcdfe3;
    color: #495057;
    font-weight: 500;
    border-radius: 8px;
  }

  .btn-light-custom:hover {
    background-color: #f8f9fa;
    color: #212529;
  }

  .table-detail-tambahan {
    border: 1px solid #e9ecef;
  }

  .table-detail-tambahan th {
    background-color: #fcfcfc;
    color: #6c757d;
    font-weight: 600;
  }
</style>

<div class="mb-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-1">
      <li class="breadcrumb-item"><a href="/admin/check-inventory" class="text-success">Inventaris</a></li>
      <li class="breadcrumb-item active" aria-current="page">Detail</li>
    </ol>
  </nav>
  <div class="d-flex justify-content-between align-items-center">
    <h2 class="fw-bold mb-0">Detail Barang</h2>

  </div>
</div>

<div class="inventory-wrapper mb-4">
  <div class="row gx-lg-5">
    <div class="col-md-5 mb-4 mb-md-0">
      <% if (barang.status_upload === 'DONE' && barang.image_url) { %>
      <img src="<%= barang.image_url %>" class="item-image" alt="<%= barang.nama_barang %>" style="max-height: 400px;">
      <% } else if (barang.status_upload === 'PENDING') { %>
      <div class="d-flex flex-column align-items-center justify-content-center img-placeholder">
        <div class="spinner-grow text-success mb-3" role="status"></div>
        <span class="text-muted">Sedang mengunggah gambar...</span>
      </div>
      <% } else { %>
      <div class="d-flex align-items-center justify-content-center img-placeholder">
        <div class="text-center text-muted">
          <i class="bi bi-image fs-1 mb-2 d-block" style="color: #ced4da;"></i>
          <span>Tidak ada gambar</span>
        </div>
      </div>
      <% } %>
    </div>

    <div class="col-md-7">
      <h3 class="fw-bold text-dark mb-4"><%= barang.nama_barang %></h3>

      <table class="table table-borderless basic-table">
        <tbody>
          <tr>
            <th>Kategori</th>
            <td>: <%= barang.kategori || '-' %></td>
          </tr>
          <tr>
            <th>Merek</th>
            <td>: <%= barang.merek || '-' %></td>
          </tr>
          <tr>
            <th>Ruangan</th>
            <td>: <%= barang.ruangan || '-' %></td>
          </tr>
          <tr>
            <th>Stok / Jumlah</th>
            <td>: <%= barang.jumlah %> <%= barang.satuan %></td>
          </tr>
          <tr>
            <td colspan="2">
              <hr class="my-1" style="color: #eee;">
            </td>
          </tr>
          <tr>
            <th>Di-input pada</th>
            <td>: <%= new Date(barang.createdAt).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></td>
          </tr>
          <tr>
            <th>Update Terakhir</th>
            <td>: <%= new Date(barang.updatedAt).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %> pukul <%= new Date(barang.updatedAt).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="inventory-wrapper mb-4">
  <h4 class="section-title mb-4">Detail Tambahan</h4>
  <% if (barang.detail && Object.keys(barang.detail).length > 0) { %>
  <div class="table-responsive">
    <table class="table table-bordered table-detail-tambahan mb-0">
      <tbody>
        <% for (let key in barang.detail) { %>
        <tr>
          <th style="width: 30%" class="py-3 px-3"><%= key %></th>
          <td class="py-3 px-3"><%= barang.detail[key] %></td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <% } else { %>
  <p class="text-muted small bg-light p-3 rounded border border-light mb-0 text-center">
    Tidak ada detail tambahan untuk barang ini.
  </p>
  <% } %>
</div>

<div class="d-flex gap-3 mb-5">
  <a href="/admin/check-inventory" class="btn btn-light-custom px-4 py-2">
    <i class="bi bi-arrow-left me-2"></i> Kembali
  </a>
  <a href="/admin/item-detail/<%= barang.id_barang %>/edit" class="btn btn-green px-4 py-2">
    <i class="bi bi-pencil me-2"></i> Edit
  </a>
</div>

<% if (barang.status_upload === 'PENDING') { %>
<script>
  const pollInterval = setInterval(async () => {
    try {
      const response = await fetch('/admin/api/status-barang/<%= barang.id_barang %>');
      const data = await response.json();

      // Jika sudah DONE, baru refresh halaman
      if (data.status === 'DONE') {
        clearInterval(pollInterval);
        window.location.reload();
      }
    } catch (err) {
      console.error("Polling error:", err);
    }
  }, 2000);
</script>
<% } %>