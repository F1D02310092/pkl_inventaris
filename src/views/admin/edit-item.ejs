<% layout('layout/boilerplate.ejs') %>
<link rel="stylesheet" href="/style/edit-item.css">

<div class="mb-4 mt-2">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-2" style="font-size: 0.9rem; font-weight: 500;">
      <li class="breadcrumb-item"><a href="/admin/check-inventory" class="text-decoration-none" style="color: #4f46e5;">Inventaris</a></li>
      <li class="breadcrumb-item"><a href="/admin/item-detail/<%= barang.id_barang %>" class="text-decoration-none" style="color: #4f46e5;">Detail</a></li>
      <li class="breadcrumb-item active" aria-current="page" style="color: #64748b;">Edit Barang</li>
    </ol>
  </nav>
  <h1 class="h3 fw-bold mb-0" style="color: #1e293b;">Edit Data Barang</h1>
</div>

<div class="card-modern p-4 p-lg-5 mb-5">
  <form action="/admin/item-detail/<%= barang.id_barang %>?_method=PUT" method="POST" enctype="multipart/form-data">

    <div class="d-flex align-items-center mb-4">
      <div class="icon-shape bg-soft-primary me-3" style="width: 40px; height: 40px; border-radius: 10px;">
        <i class="bi bi-info-circle" style="color: #4f46e5;"></i>
      </div>
      <h4 class="fw-bold mb-0" style="color: #1e293b; font-size: 1.25rem;">Informasi Dasar</h4>
    </div>

    <div class="row">
      <div class="col-md-6 mb-4">
        <label for="nama_barang" class="form-label modern-label">Nama Barang <span class="required-star">*</span></label>
        <input type="text" class="form-control modern-input" id="nama_barang" name="nama_barang" placeholder="Masukkan nama barang" required value="<%= barang.nama_barang %>" />
      </div>

      <div class="col-md-6 mb-4">
        <label for="kategori" class="form-label modern-label">Kategori <span class="required-star">*</span></label>
        <input type="text" class="form-control modern-input" id="kategori" name="kategori" list="kategoriOptions" placeholder="Pilih atau ketik kategori baru" required value="<%= barang.kategori %>" />
        <datalist id="kategoriOptions">
          <% if (typeof daftarKategori !== 'undefined') { %>
          <% daftarKategori.forEach(kat => { %>
          <option value="Elektronik"></option>
          <option value="Meubelair"></option>
          <option value="<%= kat %>"></option>
          <% }) }%>
        </datalist>
      </div>

      <div class="col-md-6 mb-4">
        <label for="merek" class="form-label modern-label">Merek</label>
        <input type="text" class="form-control modern-input" id="merek" name="merek" list="merekOptions" placeholder="Pilih atau ketik merek baru" value="<%= barang.merek %>" />
        <datalist id="merekOptions">
          <% if (typeof daftarMerek !== 'undefined') { %>
          <% daftarMerek.forEach(merek => { %>
          <option value="<%= merek %>"></option>
          <% }) %>
          <% } %>
        </datalist>
      </div>

      <div class="col-md-6 mb-4">
        <label for="ruangan" class="form-label modern-label">Ruangan <span class="required-star">*</span></label>
        <input type="text" class="form-control modern-input" id="ruangan" name="ruangan" list="ruanganOptions" placeholder="Pilih atau ketik ruangan baru" required value="<%= barang.ruangan %>" />
        <datalist id="ruanganOptions">
          <% if (typeof daftarRuangan !== 'undefined') { %>
          <% daftarRuangan.forEach(rng => { %>
          <option value="Ruang Laktasi"></option>
          <option value="Ruang Administrasi"></option>
          <option value="<%= rng %>"></option>
          <% }) %>
          <% } %>
        </datalist>
      </div>

      <div class="col-md-6 mb-4">
        <label for="jumlah" class="form-label modern-label">Kuantitas <span class="required-star">*</span></label>
        <input type="number" class="form-control modern-input" id="jumlah" name="jumlah" placeholder="0" min="0" step="1" required value="<%= barang.jumlah %>" />
      </div>

      <div class="col-md-6 mb-4">
        <label for="satuan" class="form-label modern-label">Satuan</label>
        <input type="text" class="form-control modern-input" id="satuan" name="satuan" list="satuanOptions" placeholder="Pilih satuan (misal: unit, set)" value="<%= barang.satuan %>" />
        <datalist id="satuanOptions">
          <% if (typeof daftarSatuan !== 'undefined') { %>
          <% daftarSatuan.forEach(sat => { %>
          <option value="unit"></option>
          <option value="set"></option>
          <option value="<%= sat %>"></option>
          <% }) %>
          <% } %>
        </datalist>
      </div>

      <div class="col-md-12 mb-4">
        <label for="foto" class="form-label modern-label">Foto Barang</label>
        <div class="d-flex flex-wrap align-items-center gap-4 p-3 border rounded-3 bg-light-modern">
          <% if (barang.image_url) { %>
          <div class="text-center">
            <div class="image-preview-wrapper shadow-sm mb-2">
              <img src="<%= barang.image_url %>" alt="Current Image" class="img-preview">
            </div>
            <span class="badge bg-soft-info px-2 py-1 text-info rounded-pill" style="font-size: 0.75rem;">Foto Saat Ini</span>
          </div>
          <% } %>

          <div class="flex-grow-1">
            <input id="foto" type="file" class="form-control modern-input file-input-modern" name="foto_barang" accept="image/*" capture="environment" />
            <p class="form-text mt-2 text-muted-modern mb-0" style="font-size: 0.85rem;">
              <i class="bi bi-info-circle me-1"></i> Biarkan kosong jika tidak ingin mengubah foto. Format didukung: JPG, PNG.
            </p>
          </div>
        </div>
      </div>
    </div>

    <hr class="my-5" style="border-color: #e2e8f0; opacity: 1;">

    <div class="d-flex align-items-center mb-4">
      <div class="icon-shape bg-soft-info me-3" style="width: 40px; height: 40px; border-radius: 10px;">
        <i class="bi bi-card-list text-info"></i>
      </div>
      <div>
        <h4 class="fw-bold mb-0" style="color: #1e293b; font-size: 1.25rem;">Spesifikasi Tambahan</h4>
        <span class="text-muted-modern" style="font-size: 0.85rem;">Opsional - Tambahkan atribut khusus (contoh: RAM, Warna)</span>
      </div>
    </div>

    <div id="dynamic-detail-container">
      <% if (barang.detail && Object.keys(barang.detail).length > 0) { %>
      <% for (let key in barang.detail) { %>
      <div class="row mb-3 align-items-center detail-row">
        <div class="col-md-5 mb-2 mb-md-0">
          <input type="text" class="form-control modern-input" name="detailKey" value="<%= key %>" placeholder="Nama Atribut">
        </div>
        <div class="col-md-6 mb-2 mb-md-0">
          <input type="text" class="form-control modern-input" name="detailValue" value="<%= barang.detail[key] %>" placeholder="Nilai Atribut">
        </div>
        <div class="col-md-1 text-end">
          <button class="btn btn-icon-only bg-soft-danger text-danger btn-hapus border-0 shadow-sm" type="button" title="Hapus baris">
            <i class="bi bi-trash3 pointer-events-none"></i>
          </button>
        </div>
      </div>
      <% } %>
      <% } %>
    </div>

    <button type="button" id="btn-tambah-detail" class="btn btn-outline-dashed mt-2 mb-5 w-100">
      <i class="bi bi-plus-lg me-2"></i> Tambah Atribut Baru
    </button>

    <div class="d-flex justify-content-end gap-3 border-top pt-4">
      <a href="/admin/item-detail/<%= barang.id_barang %>" class="btn btn-outline-modern px-4 py-2">
        Batal
      </a>
      <button type="submit" class="btn btn-primary-modern px-5 py-2 shadow-sm">
        <i class="bi bi-check2-circle me-2"></i> Simpan Perubahan
      </button>
    </div>

  </form>
</div>

<script>
  document.getElementById("btn-tambah-detail").addEventListener("click", function() {
    const container = document.getElementById("dynamic-detail-container");

    const row = document.createElement("div");
    row.className = "row mb-3 align-items-center detail-row";

    row.innerHTML = `
      <div class="col-md-5 mb-2 mb-md-0">
        <input type="text" class="form-control modern-input" name="detailKey" placeholder="Nama Atribut (Contoh: Warna, RAM)">
      </div>
      <div class="col-md-6 mb-2 mb-md-0">
        <input type="text" class="form-control modern-input" name="detailValue" placeholder="Nilai (Contoh: Hitam, 16GB)">
      </div>
      <div class="col-md-1 text-end">
        <button class="btn btn-icon-only bg-soft-danger text-danger btn-hapus border-0 shadow-sm" type="button" title="Hapus baris">
          <i class="bi bi-trash3 pointer-events-none"></i>
        </button>
      </div>
    `;

    container.appendChild(row);
  });

  document.getElementById("dynamic-detail-container").addEventListener("click", function(e) {
    const hapusBtn = e.target.closest('.btn-hapus');
    if (hapusBtn) {
      hapusBtn.closest('.detail-row').remove();
    }
  });
</script>