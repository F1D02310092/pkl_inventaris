<% layout('layout/boilerplate.ejs') %>

<style>
  .inventory-wrapper {
    background-color: #ffffff;
    border-radius: 12px;
    border: 1px solid #f0f0f0;
    padding: 30px;
  }

  .section-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #212529;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #f0f0f0;
  }

  .btn-green {
    background-color: #34c759;
    border-color: #34c759;
    color: white;
    font-weight: 500;
    border-radius: 8px;
  }

  .btn-green:hover {
    background-color: #2db84d;
    color: white;
  }

  .btn-light-custom {
    background-color: #ffffff;
    border: 1px solid #dcdfe3;
    color: #495057;
    font-weight: 500;
    border-radius: 8px;
  }

  .btn-light-custom:hover {
    background-color: #f8f9fa;
    color: #212529;
  }

  .btn-outline-green {
    color: #34c759;
    border-color: #34c759;
    font-weight: 500;
    border-radius: 8px;
  }

  .btn-outline-green:hover {
    background-color: #34c759;
    color: white;
  }

  /* Styling khusus input form & preview */
  .form-label {
    font-weight: 500;
    color: #495057;
    font-size: 0.95rem;
  }

  .custom-input {
    border-radius: 8px;
    border: 1px solid #ced4da;
    padding: 0.5rem 0.75rem;
  }

  .custom-input:focus {
    border-color: #34c759;
    box-shadow: 0 0 0 0.25rem rgba(52, 199, 89, 0.25);
  }

  .required-star {
    color: #dc3545;
  }

  .img-preview {
    max-width: 150px;
    border-radius: 8px;
    border: 1px solid #e9ecef;
    object-fit: cover;
  }
</style>

<div class="mb-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-1">
      <li class="breadcrumb-item"><a href="/admin/check-inventory" class="text-decoration-none text-success">Inventory</a></li>
      <li class="breadcrumb-item"><a href="/admin/item-detail/<%= barang.id_barang %>" class="text-decoration-none text-success">Detail</a></li>
      <li class="breadcrumb-item active" aria-current="page">Edit</li>
    </ol>
  </nav>
  <h2 class="fw-bold mb-0">Edit Data Barang</h2>
</div>

<div class="inventory-wrapper mb-5">
  <form action="/admin/item-detail/<%= barang.id_barang %>?_method=PUT" method="POST" enctype="multipart/form-data">

    <h4 class="section-title mb-4">Informasi Dasar</h4>

    <div class="row">
      <div class="col-md-6 mb-4">
        <label for="nama_barang" class="form-label">Nama Barang <span class="required-star">*</span></label>
        <input type="text" class="form-control custom-input" id="nama_barang" name="nama_barang" value="<%= barang.nama_barang %>" required />
      </div>

      <div class="col-md-6 mb-4">
        <label for="nomor_seri" class="form-label">Nomor Seri</label>
        <input type="text" class="form-control custom-input" id="nomor_seri" name="nomor_seri" value="<%= barang.nomor_seri || '' %>" />
      </div>

      <div class="col-md-12 mb-4">
        <label for="foto" class="form-label">Foto Barang</label>
        <div class="d-flex align-items-center gap-4">
          <% if (barang.image_url) { %>
          <div>
            <img src="<%= barang.image_url %>" alt="Current Image" class="img-preview mb-2">
            <div class="text-muted small text-center">Foto Saat Ini</div>
          </div>
          <% } %>

          <div class="flex-grow-1">
            <input id="foto" type="file" class="form-control custom-input" name="foto_barang" accept="image/*" capture="environment" />
            <div class="form-text mt-1 text-muted small">Biarkan kosong jika tidak ingin mengubah foto.</div>
            <div class="form-text mt-1 text-muted small">Format: JPG, PNG, JPEG.</div>
          </div>
        </div>
      </div>
    </div>

    <h4 class="section-title mb-4 mt-3">Detail Tambahan</h4>

    <div id="dynamic-detail-container">
      <% if (barang.detail && Object.keys(barang.detail).length > 0) { %>
      <% for (let key in barang.detail) { %>
      <div class="row mb-3 align-items-center detail-row">
        <div class="col-md-5 mb-2 mb-md-0">
          <input type="text" class="form-control custom-input" name="detailKey" value="<%= key %>" placeholder="Nama Atribut">
        </div>
        <div class="col-md-6 mb-2 mb-md-0">
          <input type="text" class="form-control custom-input" name="detailValue" value="<%= barang.detail[key] %>" placeholder="Nilai Atribut">
        </div>
        <div class="col-md-1 text-end">
          <button class="btn btn-outline-danger btn-hapus p-2 border-0" type="button" title="Hapus baris">
            <i class="bi bi-trash fs-5 pointer-events-none"></i>
          </button>
        </div>
      </div>
      <% } %>
      <% } %>
    </div>

    <button type="button" id="btn-tambah-detail" class="btn btn-outline-green mb-5">
      <i class="bi bi-plus-lg me-1"></i> Tambah Detail
    </button>

    <div class="d-flex justify-content-end gap-3 border-top pt-4">
      <a href="/admin/item-detail/<%= barang.id_barang %>" class="btn btn-light-custom px-4 py-2">
        Batal
      </a>
      <button type="submit" class="btn btn-green px-5 py-2">
        <i class="bi bi-check2-circle me-2"></i> Simpan Perubahan
      </button>
    </div>

  </form>
</div>

<script>
  document.getElementById("btn-tambah-detail").addEventListener("click", function() {
    const container = document.getElementById("dynamic-detail-container");

    const row = document.createElement("div");
    row.className = "row mb-3 align-items-center detail-row";

    row.innerHTML = `
      <div class="col-md-5 mb-2 mb-md-0">
        <input type="text" class="form-control custom-input" name="detailKey" placeholder="Nama Atribut (Contoh: Warna, RAM)">
      </div>
      <div class="col-md-6 mb-2 mb-md-0">
        <input type="text" class="form-control custom-input" name="detailValue" placeholder="Nilai (Contoh: Hitam, 16GB)">
      </div>
      <div class="col-md-1 text-end">
        <button class="btn btn-outline-danger btn-hapus p-2 border-0" type="button" title="Hapus baris">
          <i class="bi bi-trash fs-5 pointer-events-none"></i>
        </button>
      </div>
    `;

    container.appendChild(row);
  });

  document.getElementById("dynamic-detail-container").addEventListener("click", function(e) {
    // Mencari elemen terdekat dengan class btn-hapus
    const hapusBtn = e.target.closest('.btn-hapus');
    if (hapusBtn) {
      hapusBtn.closest('.detail-row').remove();
    }
  });
</script>