<% layout('layout/boilerplate.ejs') %>
<link rel="stylesheet" href="/style/input-inventory.css">

<div class="mb-4 mt-2">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-2" style="font-size: 0.9rem; font-weight: 500;">
      <li class="breadcrumb-item"><a href="/admin/check-inventory" class="text-decoration-none" style="color: #4f46e5;">Inventaris</a></li>
      <li class="breadcrumb-item active" aria-current="page" style="color: #64748b;">Input Barang</li>
    </ol>
  </nav>
  <h1 class="h3 fw-bold mb-0" style="color: #1e293b;">Input Data Barang</h1>
</div>

<div class="card-modern p-4 p-lg-5 mb-5">
  <form action="/admin/input-inventory?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data" autocomplete="off">

    <div class="d-flex align-items-center mb-4">
      <div class="icon-shape bg-soft-primary me-3" style="width: 40px; height: 40px; border-radius: 10px;">
        <i class="bi bi-box-seam" style="color: #4f46e5;"></i>
      </div>
      <h4 class="fw-bold mb-0" style="color: #1e293b; font-size: 1.25rem;">Informasi Utama</h4>
    </div>

    <div class="row">
      <div class="col-md-6 mb-4">
        <label for="nama_barang" class="form-label modern-label">Nama Barang <span class="required-star">*</span></label>
        <input type="text" class="form-control modern-input" id="nama_barang" name="nama_barang" placeholder="Masukkan nama barang" required />
      </div>

      <div class="col-md-6 mb-4">
        <label for="kategori" class="form-label modern-label">Kategori <span class="required-star">*</span></label>
        <input type="text" class="form-control modern-input" id="kategori" name="kategori" list="kategoriOptions" placeholder="Pilih atau ketik kategori baru" required />
        <datalist id="kategoriOptions">
          <% if (typeof daftarKategori !== 'undefined') { %>
          <% daftarKategori.forEach(kat => { %>
          <option value="<%= capitalizeEachWord(kat) %>"></option>
          <% }) }%>
        </datalist>
      </div>

      <div class="col-md-6 mb-4">
        <label for="merek" class="form-label modern-label">Merek</label>
        <input type="text" class="form-control modern-input" id="merek" name="merek" list="merekOptions" placeholder="Pilih atau ketik merek baru" />
        <datalist id="merekOptions">
          <% if (typeof daftarMerek !== 'undefined') { %>
          <% daftarMerek.forEach(merek => { %>
          <option value="<%= capitalizeEachWord(merek) %>"></option>
          <% }) %>
          <% } %>
        </datalist>
      </div>

      <div class="col-md-6 mb-4">
        <label for="ruangan" class="form-label modern-label">Ruangan <span class="required-star">*</span></label>
        <input type="text" class="form-control modern-input" id="ruangan" name="ruangan" list="ruanganOptions" placeholder="Pilih atau ketik ruangan baru" required />
        <datalist id="ruanganOptions">
          <% if (typeof daftarRuangan !== 'undefined') { %>
          <% daftarRuangan.forEach(rng => { %>
          <option value="<%= capitalizeEachWord(rng) %>"></option>
          <% }) %>
          <% } %>
        </datalist>
      </div>

      <div class="col-md-6 mb-4">
        <label for="jumlah" class="form-label modern-label">Kuantitas <span class="required-star">*</span></label>
        <input type="number" class="form-control modern-input" id="jumlah" name="jumlah" placeholder="0" min="0" step="1" required />
      </div>

      <div class="col-md-6 mb-4">
        <label for="satuan" class="form-label modern-label">Satuan</label>
        <input type="text" class="form-control modern-input" id="satuan" name="satuan" list="satuanOptions" placeholder="Pilih satuan (misal: unit, set)" />
        <datalist id="satuanOptions">
          <% if (typeof daftarSatuan !== 'undefined') { %>
          <% daftarSatuan.forEach(sat => { %>
          <option value="<%= capitalizeEachWord(sat) %>"></option>
          <% }) %>
          <% } %>
        </datalist>
      </div>

      <div class="col-md-6 mb-4">
        <label for="kondisi" class="form-label modern-label">Kondisi Awal <span class="required-star">*</span></label>
        <select class="form-select modern-input" id="kondisi" name="kondisi" required>
          <option value="Belum Dicek" selected>Belum Dicek</option>
          <option value="Baik">Baik</option>
          <option value="Rusak Ringan">Rusak Ringan</option>
          <option value="Rusak Berat">Rusak Berat</option>
        </select>
      </div>

      <div class="col-md-6 mb-4">
        <label for="jadwal_pengecekan" class="form-label modern-label">Jadwal Cek Rutin <span class="required-star">*</span></label>
        <select class="form-select modern-input" id="jadwal_pengecekan" name="jadwal_pengecekan" required>
          <option value="Tak Terjadwal" selected>Tak Terjadwal</option>
          <option value="Harian">Harian</option>
          <option value="Mingguan">Mingguan</option>
          <option value="Bulanan">Bulanan</option>
          <option value="Tahunan">Tahunan</option>
        </select>
      </div>

      <div class="col-md-6 mb-3" id="container-tanggal-pengecekan">
        <label for="tanggal_pengecekan" class="form-label modern-label">Tanggal Pengecekan</label>
        <input type="datetime-local" class="form-control modern-input" id="tanggal_pengecekan" name="tanggal_pengecekan">
        <div class="form-text mt-1 text-muted-modern" style="font-size: 0.8rem;">
          <em><i class="bi bi-calendar-event me-1"></i>Default: Tanggal Hari ini. Ubah melalui menu di atas jika diperlukan.</em>
        </div>
      </div>

      <div class="col-md-12 mb-4">
        <label for="foto" class="form-label modern-label">Foto Barang <span class="required-star"></span></label>
        <div class="p-3 border rounded-3 bg-light-modern">
          <input id="foto" type="file" class="form-control modern-input file-input-modern bg-white" name="foto_barang" accept="image/*" capture="environment" />
          <p class="form-text mt-2 text-muted-modern mb-0" style="font-size: 0.85rem;">
            <i class="bi bi-info-circle me-1"></i> Format didukung: JPG, PNG, JPEG, WEBP.
          </p>
        </div>
      </div>
    </div>

    <hr class="my-5" style="border-color: #e2e8f0; opacity: 1;">

    <div class="d-flex align-items-center mb-4">
      <div class="icon-shape bg-soft-info me-3" style="width: 40px; height: 40px; border-radius: 10px;">
        <i class="bi bi-card-list text-info"></i>
      </div>
      <div>
        <h4 class="fw-bold mb-0" style="color: #1e293b; font-size: 1.25rem;">Detail Tambahan</h4>
        <span class="text-muted-modern" style="font-size: 0.85rem;">Opsional</span>
      </div>
    </div>

    <div id="dynamic-detail-container"></div>

    <button type="button" id="btn-tambah-detail" class="btn btn-outline-dashed mt-2 mb-5 w-100">
      <i class="bi bi-plus-lg me-2"></i> Tambah Atribut Baru
    </button>

    <div class="d-flex justify-content-end gap-3 border-top pt-4">
      <a href="/admin/check-inventory" class="btn btn-outline-modern px-4 py-2">
        Batal
      </a>
      <button type="submit" class="btn btn-primary-modern px-5 py-2 shadow-sm">
        <i class="bi bi-save me-2"></i> Simpan Barang
      </button>
    </div>

  </form>
</div>

<script>
  document.getElementById("btn-tambah-detail").addEventListener("click", function() {
    const container = document.getElementById("dynamic-detail-container");

    const row = document.createElement("div");
    row.className = "row mb-3 align-items-center detail-row";

    row.innerHTML = `
      <div class="col-md-5 mb-2 mb-md-0">
        <input type="text" class="form-control modern-input" name="detailKey" placeholder="Nama Atribut (Contoh: Bahan, Warna)">
      </div>
      <div class="col-md-6 mb-2 mb-md-0">
        <input type="text" class="form-control modern-input" name="detailValue" placeholder="Nilai (Contoh: Kayu, Hitam)">
      </div>
      <div class="col-md-1 text-end">
        <button class="btn btn-icon-only bg-soft-danger text-danger btn-hapus border-0 shadow-sm" type="button" title="Hapus baris">
          <i class="bi bi-trash3 pointer-events-none"></i>
        </button>
      </div>
    `;

    container.appendChild(row);
  });

  document.getElementById("dynamic-detail-container").addEventListener("click", function(e) {
    const hapusBtn = e.target.closest('.btn-hapus');
    if (hapusBtn) {
      hapusBtn.closest('.detail-row').remove();
    }
  });

  document.addEventListener("DOMContentLoaded", function() {
    // 1. Set Default Tanggal ke Hari Ini
    const dateInput = document.getElementById('tanggal_pengecekan');
    if (dateInput) {
      // Dapatkan tanggal hari ini dengan format YYYY-MM-DD
      const today = new Date();
      today.setMinutes(today.getMinutes() - today.getTimezoneOffset());
      dateInput.value = today.toISOString().split('T')[0];
    }

    // 2. Logika Sembunyikan Tanggal Jika "Belum Dicek" (Khusus halaman Input/Edit)
    const kondisiSelect = document.querySelector('select[name="kondisi_terkini"]');
    const containerTanggal = document.getElementById('container-tanggal-pengecekan');

    if (kondisiSelect && containerTanggal) {
      // Fungsi untuk mengecek status
      const toggleTanggal = () => {
        if (kondisiSelect.value === 'Belum Dicek') {
          containerTanggal.style.display = 'none';
        } else {
          containerTanggal.style.display = 'block';
        }
      };

      // Jalankan saat pertama kali dimuat
      toggleTanggal();

      // Jalankan setiap kali pilihan dropdown diubah
      kondisiSelect.addEventListener('change', toggleTanggal);
    }
  });
</script>