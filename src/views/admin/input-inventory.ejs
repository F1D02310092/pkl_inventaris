<% layout('layout/boilerplate.ejs') %>

<style>
  .inventory-wrapper {
    background-color: #ffffff;
    border-radius: 12px;
    border: 1px solid #f0f0f0;
    padding: 30px;
  }

  .section-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #212529;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #f0f0f0;
  }

  .btn-green {
    background-color: #34c759;
    border-color: #34c759;
    color: white;
    font-weight: 500;
    border-radius: 8px;
  }

  .btn-green:hover {
    background-color: #2db84d;
    color: white;
  }

  .btn-light-custom {
    background-color: #ffffff;
    border: 1px solid #dcdfe3;
    color: #495057;
    font-weight: 500;
    border-radius: 8px;
  }

  .btn-light-custom:hover {
    background-color: #f8f9fa;
    color: #212529;
  }

  .btn-outline-green {
    color: #34c759;
    border-color: #34c759;
    font-weight: 500;
    border-radius: 8px;
  }

  .btn-outline-green:hover {
    background-color: #34c759;
    color: white;
  }

  .form-label {
    font-weight: 500;
    color: #495057;
    font-size: 0.95rem;
  }

  .custom-input {
    border-radius: 8px;
    border: 1px solid #ced4da;
    padding: 0.5rem 0.75rem;
  }

  .custom-input:focus {
    border-color: #34c759;
    box-shadow: 0 0 0 0.25rem rgba(52, 199, 89, 0.25);
  }

  .required-star {
    color: #dc3545;
  }
</style>

<div class="py-3 mb-4 d-flex justify-content-between align-items-center">
  <h2 class="fw-bold mb-0">Input Data Barang</h2>

  <nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-0">
      <li class="breadcrumb-item">
        <a href="/admin/check-inventory" class="text-success">Inventaris</a>
      </li>
      <li class="breadcrumb-item active" aria-current="page">
        Input Barang
      </li>
    </ol>
  </nav>
</div>

<div class="inventory-wrapper mb-5">
  <form action="/admin/input-inventory" method="POST" enctype="multipart/form-data">

    <h4 class="section-title mb-4">Informasi Utama</h4>

    <div class="row">
      <div class="col-md-6 mb-4">
        <label for="nama_barang" class="form-label">Nama Barang <span class="required-star">*</span></label>
        <input type="text" class="form-control custom-input" id="nama_barang" name="nama_barang" placeholder="Masukkan nama barang" required />
      </div>

      <div class="col-md-6 mb-4">
        <label for="kategori" class="form-label">Kategori <span class="required-star">*</span></label>
        <input type="text" class="form-control custom-input" id="kategori" name="kategori" list="kategoriOptions" placeholder="Pilih atau ketik kategori baru" required />
        <datalist id="kategoriOptions">
          <% if (typeof daftarKategori !== 'undefined') { %>
          <% daftarKategori.forEach(kat => { %>
          <option value="Elektronik"></option>
          <option value="Meubelair"></option>
          <option value="<%= kat %>"></option>
          <% }) }%>
        </datalist>
      </div>

      <div class="col-md-6 mb-4">
        <label for="merek" class="form-label">Merek</label>
        <input type="text" class="form-control custom-input" id="merek" name="merek" list="merekOptions" placeholder="Pilih atau ketik merek baru" />
        <datalist id="merekOptions">
          <% if (typeof daftarMerek !== 'undefined') { %>
          <% daftarMerek.forEach(merek => { %>
          <option value="<%= merek %>"></option>
          <% }) %>
          <% } %>
        </datalist>
      </div>

      <div class="col-md-6 mb-4">
        <label for="ruangan" class="form-label">Ruangan <span class="required-star">*</span></label>
        <input type="text" class="form-control custom-input" id="ruangan" name="ruangan" list="ruanganOptions" placeholder="Pilih atau ketik ruangan baru" required />
        <datalist id="ruanganOptions">
          <% if (typeof daftarRuangan !== 'undefined') { %>
          <% daftarRuangan.forEach(rng => { %>
          <option value="Ruang Laktasi"></option>
          <option value="Ruang Administrasi"></option>
          <option value="<%= rng %>"></option>
          <% }) %>
          <% } %>

        </datalist>
      </div>

      <div class="col-md-6 mb-4">
        <label for="jumlah" class="form-label">Jumlah <span class="required-star">*</span></label>
        <input type="number" class="form-control custom-input" id="jumlah" name="jumlah" placeholder="Masukkan jumlah barang" min="0" required />
      </div>

      <div class="col-md-6 mb-4">
        <label for="satuan" class="form-label">Satuan</label>
        <input type="text" class="form-control custom-input" id="satuan" name="satuan" list="satuanOptions" placeholder="Pilih atau ketik satuan (misal: buah, set)" />
        <datalist id="satuanOptions">
          <% if (typeof daftarSatuan !== 'undefined') { %>
          <% daftarSatuan.forEach(sat => { %>
          <option value="buah (unit)"></option>
          <option value="set"></option>
          <option value="<%= sat %>"></option>
          <% }) %>
          <% }  %>

        </datalist>
      </div>

      <div class="col-md-12 mb-4">
        <label for="foto" class="form-label">Foto Barang <span class="required-star">*</span></label>
        <input id="foto" type="file" class="form-control custom-input" name="foto_barang" accept="image/*" capture="environment" required />
        <div class="form-text mt-1 text-muted small">Format didukung: JPG, PNG, JPEG.</div>
      </div>
    </div>

    <h4 class="section-title mb-4 mt-3">Detail Tambahan (Opsional)</h4>

    <div id="dynamic-detail-container">
    </div>

    <button type="button" id="btn-tambah-detail" class="btn btn-outline-green mb-5">
      <i class="bi bi-plus-lg me-1"></i> Tambah Detail
    </button>

    <div class="d-flex justify-content-end gap-3 border-top pt-4">
      <a href="/admin/check-inventory" class="btn btn-light-custom px-4 py-2">
        Batal
      </a>
      <button type="submit" class="btn btn-green px-5 py-2">
        <i class="bi bi-save me-2"></i> Simpan Barang
      </button>
    </div>

  </form>
</div>

<script>
  document.getElementById("btn-tambah-detail").addEventListener("click", function() {
    const container = document.getElementById("dynamic-detail-container");

    const row = document.createElement("div");
    row.className = "row mb-3 align-items-center detail-row";

    row.innerHTML = `
      <div class="col-md-5 mb-2 mb-md-0">
        <input type="text" class="form-control custom-input" name="detailKey" placeholder="Contoh: Warna">
      </div>
      <div class="col-md-6 mb-2 mb-md-0">
        <input type="text" class="form-control custom-input" name="detailValue" placeholder="Contoh: Hitam">
      </div>
      <div class="col-md-1 text-end">
        <button class="btn btn-outline-danger btn-hapus p-2 border-0" type="button" title="Hapus baris">
          <i class="bi bi-trash fs-5 pointer-events-none"></i>
        </button>
      </div>
    `;

    container.appendChild(row);
  });

  document.getElementById("dynamic-detail-container").addEventListener("click", function(e) {
    const hapusBtn = e.target.closest('.btn-hapus');
    if (hapusBtn) {
      hapusBtn.closest('.detail-row').remove();
    }
  });
</script>