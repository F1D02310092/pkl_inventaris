<style>
  .modern-navbar {
    background-color: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(226, 232, 240, 0.8);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
    position: sticky;
    top: 0;
    z-index: 1030;
    padding: 0.75rem 0;
  }

  .btn-toggle-modern {
    background: transparent;
    border: none;
    color: #475569;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 0.5rem;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .btn-toggle-modern:hover {
    background-color: #f1f5f9;
    color: #0f172a;
  }

  .navbar-brand-modern {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: #0f172a;
    font-weight: 700;
    font-size: 1.25rem;
  }

  .brand-icon {
    background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);
    color: white;
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.75rem;
    font-size: 1.1rem;
    box-shadow: 0 2px 4px rgba(79, 70, 229, 0.3);
  }


  .role-badge {
    padding: 0.35rem 0.85rem;
    border-radius: 50rem;
    font-size: 0.85rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .role-badge-admin {
    background-color: #e0e7ff;
    color: #475569;
  }

  .role-badge-user {
    background-color: #f1f5f9;
    color: #475569;
  }



  .offcanvas-modern {
    background-color: #ffffff;
    border-right: none !important;
    box-shadow: 4px 0 15px rgba(0, 0, 0, 0.05);
    width: 300px !important;
  }

  .offcanvas-header-modern {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid #f1f5f9;
  }

  .btn-close-modern {
    background: transparent;
    border: none;
    font-size: 1.2rem;
    color: #94a3b8;
    cursor: pointer;
    transition: color 0.2s;
  }

  .btn-close-modern:hover {
    color: #ef4444;
  }

  .nav-modern-list-vertical {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nav-link-modern {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    color: #64748b;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    border-radius: 0.5rem;
    transition: all 0.2s ease;
  }

  .nav-link-modern i {
    font-size: 1.2rem;
    transition: transform 0.2s;
  }

  .nav-link-modern:hover {
    color: #1e293b;
    background-color: #f8fafc;
  }

  .nav-link-modern:hover i {
    transform: scale(1.1);
    color: #4f46e5;
  }

  .nav-link-modern.active {
    color: #4f46e5;
    background-color: #e0e7ff;
    font-weight: 600;
  }

  .nav-link-modern.active i {
    color: #4f46e5;
  }

  .nav-menu-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #94a3b8;
    font-weight: 700;
    margin: 1.5rem 0 0.5rem 1rem;
  }

  .offcanvas-footer-modern {
    padding: 1.25rem 1.5rem;
    border-top: 1px solid #f1f5f9;
    background-color: #ffffff;
    margin-top: auto;
  }

  .nav-link-danger {
    color: #ef4444;
  }

  .nav-link-danger:hover {
    color: #ef4444;
    background-color: #fef2f2;
  }

  .nav-link-danger:hover i {
    color: #ef4444;
  }
</style>

<nav class="modern-navbar">
  <div class="container d-flex align-items-center justify-content-between">

    <div class="d-flex align-items-center gap-3">
      <button class="btn-toggle-modern shadow-sm" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar">
        <i class="bi bi-list"></i>
      </button>

      <a class="navbar-brand-modern" href="/">
        <div class="brand-icon">
          <i class="bi bi-box-seam-fill"></i>
        </div>
        <span class="d-none d-sm-inline">Sistem Inventaris</span>
      </a>
    </div>

    <% if (typeof currUser !== 'undefined' && currUser) { %>
    <div class="d-flex align-items-center">
      <span class="role-badge <%= currUser.role === 'admin' ? 'role-badge-admin' : 'role-badge-user' %> shadow-sm">
        <i class="bi <%= currUser.role === 'admin' ? 'bi-shield-check' : 'bi-person' %>"></i>
        <span class="d-none d-sm-inline"><%= currUser.role === 'admin' ? 'Admin' : 'User' %></span>
      </span>
    </div>
    <% } %>

  </div>
</nav>

<div class="offcanvas offcanvas-start offcanvas-modern" tabindex="-1" id="offcanvasNavbar" aria-labelledby="offcanvasNavbarLabel">

  <div class="offcanvas-header offcanvas-header-modern d-flex align-items-center justify-content-between">
    <a href="/" class="navbar-brand-modern">
      <div class="brand-icon">
        <i class="bi bi-box-seam-fill"></i>
      </div>
      <span class="fw-bold" style="color: #1e293b;">Menu Utama</span>
    </a>
    <button type="button" class="btn-close-modern" data-bs-dismiss="offcanvas" aria-label="Close">
      <i class="bi bi-x-lg"></i>
    </button>
  </div>

  <div class="offcanvas-body px-3 py-4">
    <ul class="nav-modern-list-vertical">

      <div class="nav-menu-label">Dashboard</div>
      <li>
        <a class="nav-link-modern <%= currentPath === '/' ? 'active' : '' %>" href="/">
          <i class="bi bi-grid-1x2"></i> <span>Dashboard</span>
        </a>
      </li>

      <div class="nav-menu-label">Manajemen</div>
      <li>
        <a class="nav-link-modern <%= currentPath && (currentPath.includes('/admin/check-inventory') || currentPath.includes('/admin/item-detail')) ? 'active' : '' %>" href="/admin/check-inventory">
          <i class="bi bi-view-list"></i> <span>Data Inventaris</span>
        </a>
      </li>
      <li>
        <a class="nav-link-modern <%= currentPath && currentPath.includes('/admin/input-inventory') ? 'active' : '' %>" href="/admin/input-inventory">
          <i class="bi bi-plus-circle"></i> <span>Input Barang Baru</span>
        </a>
      </li>

    </ul>
  </div>

  <div class="offcanvas-footer-modern">
    <% if(typeof currUser !== 'undefined' && currUser) { %>
    <a class="nav-link-modern nav-link-danger" href="/logout">
      <i class="bi bi-box-arrow-right"></i> <span>Keluar</span>
    </a>
    <% } else { %>
    <a class="nav-link-modern <%= typeof currentPath !== 'undefined' && currentPath === '/login' ? 'active' : '' %>" href="/login">
      <i class="bi bi-box-arrow-in-right"></i> <span>Login</span>
    </a>
    <% } %>
  </div>

</div>